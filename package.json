{
  "name": "@mongez/react-localization",
  "version": "3.4.4",
  "description": "React adapter for @mongez/localization. Adds a JSX-aware placeholder converter so `trans(...)` can interpolate React elements, plus `transX` — a JSX-bound translate function that works regardless of the globally configured converter.",
  "main": "src/index.ts",
  "sideEffects": false,
  "author": "hassanzohdy",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@mongez/localization": ">=3.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@mongez/localization": "^3.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "happy-dom": "^15.7.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hassanzohdy/mongez-react-localization"
  },
  "keywords": [
    "i18n",
    "localization",
    "translation",
    "trans",
    "transX",
    "jsx",
    "jsx-converter",
    "language",
    "react",
    "react-native",
    "mongez"
  ],
  "license": "MIT"
}
